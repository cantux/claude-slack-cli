# Slack app credentials (Socket Mode — no public URL required)
SLACK_BOT_TOKEN=xoxb-...        # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...        # App-Level Token with connections:write

# Where Claude Code should run. This is the project Claude works on,
# NOT the bot's own directory. Session state file lives here too.
CLAUDE_PROJECT_DIR=/home/ctuk/Projects/your-project

# Path to the claude binary (use `which claude` to find it).
CLAUDE_BIN=claude

# default | acceptEdits | plan | bypassPermissions
# acceptEdits = auto-accept file edits, still prompts for shell etc.
# bypassPermissions = fully autonomous (riskier).
CLAUDE_PERMISSION_MODE=acceptEdits

# Per-turn timeout in seconds.
CLAUDE_TIMEOUT_SECONDS=600
